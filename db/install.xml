<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/ai_grading/db" VERSION="2026060901" COMMENT="XMLDB file for local_ai_grading"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_ai_grading_config" COMMENT="AI grading configuration for one course VPL activity">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="vplid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="teacherid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="prompt" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="rubricfingerprint" TYPE="char" LENGTH="40" NOTNULL="false" SEQUENCE="false" COMMENT="Hash of criteria, levels and manual references; detects critical config changes"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course_vpl_uq" UNIQUE="true" FIELDS="courseid, vplid"/>
        <INDEX NAME="teacher_ix" UNIQUE="false" FIELDS="teacherid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ai_grading_criterion" COMMENT="Rubric criteria for an AI grading configuration">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="configid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="weight" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="config_fk" TYPE="foreign" FIELDS="configid" REFTABLE="local_ai_grading_config" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="config_sort_ix" UNIQUE="false" FIELDS="configid, sortorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ai_grading_level" COMMENT="Performance levels for one rubric criterion">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="criterionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="percentage" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="criterion_fk" TYPE="foreign" FIELDS="criterionid" REFTABLE="local_ai_grading_criterion" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="criterion_sort_ix" UNIQUE="false" FIELDS="criterionid, sortorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ai_grading_manual" COMMENT="Manual reference grading records">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="configid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="studentid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="submissionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="selectiontype" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="specific" SEQUENCE="false"/>
        <FIELD NAME="totalgrade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="generalobservations" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="config_fk" TYPE="foreign" FIELDS="configid" REFTABLE="local_ai_grading_config" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="config_ix" UNIQUE="false" FIELDS="configid"/>
        <INDEX NAME="student_ix" UNIQUE="false" FIELDS="studentid"/>
        <INDEX NAME="submission_ix" UNIQUE="false" FIELDS="submissionid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ai_grading_mancrit" COMMENT="Criterion details for manual reference grading">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="manualid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="criterionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="levelid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="observation" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="manual_fk" TYPE="foreign" FIELDS="manualid" REFTABLE="local_ai_grading_manual" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="manual_crit_uq" UNIQUE="true" FIELDS="manualid, criterionid"/>
        <INDEX NAME="level_ix" UNIQUE="false" FIELDS="levelid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ai_grading_aitest" COMMENT="AI test grading runs">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="configid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="studentid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="submissionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="totalgrade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="generalfeedback" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timesent" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timereceived" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="config_fk" TYPE="foreign" FIELDS="configid" REFTABLE="local_ai_grading_config" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="config_ix" UNIQUE="false" FIELDS="configid"/>
        <INDEX NAME="student_ix" UNIQUE="false" FIELDS="studentid"/>
        <INDEX NAME="submission_ix" UNIQUE="false" FIELDS="submissionid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ai_grading_aitcrit" COMMENT="Criterion details for AI test grading runs">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="aitestid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="criterionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="levelid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="aidetail" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="aitest_fk" TYPE="foreign" FIELDS="aitestid" REFTABLE="local_ai_grading_aitest" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="test_crit_uq" UNIQUE="true" FIELDS="aitestid, criterionid"/>
        <INDEX NAME="level_ix" UNIQUE="false" FIELDS="levelid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ai_grading_result" COMMENT="Future real AI grading results">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="configid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="studentid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="submissionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="attemptnumber" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timesubmitted" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="aistatus" TYPE="char" LENGTH="50" NOTNULL="true" DEFAULT="pending" SEQUENCE="false"/>
        <FIELD NAME="aitotalgrade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="finaltotalgrade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="finalfeedback" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="studentfeedback" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="errordetail" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="reviewedby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="publishedby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timeevaluated" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timereviewed" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timepublished" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timestudentviewed" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="config_fk" TYPE="foreign" FIELDS="configid" REFTABLE="local_ai_grading_config" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="config_sub_uq" UNIQUE="true" FIELDS="configid, submissionid"/>
        <INDEX NAME="student_ix" UNIQUE="false" FIELDS="studentid"/>
        <INDEX NAME="status_ix" UNIQUE="false" FIELDS="aistatus"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ai_grading_rescrit" COMMENT="Criterion details for future real AI grading results">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="resultid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="criterionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="levelid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Level suggested by the AI"/>
        <FIELD NAME="finallevelid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Level chosen by the teacher (final)"/>
        <FIELD NAME="aigrade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="finalgrade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="aidetail" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="finaldetail" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="result_fk" TYPE="foreign" FIELDS="resultid" REFTABLE="local_ai_grading_result" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="result_crit_uq" UNIQUE="true" FIELDS="resultid, criterionid"/>
        <INDEX NAME="level_ix" UNIQUE="false" FIELDS="levelid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
